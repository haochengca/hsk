    "test:recognition": "node --test tests/recognition-core.spec.js",
    "test:submissions": "node --test tests/submissions-judge-detail.spec.js",
    "test:tasks": "node --test tests/task-service.spec.js tests/tasks-api.spec.js"
  }
}

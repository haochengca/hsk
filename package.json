{
  "name": "hsk-study-server",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "pg": "^8.19.0"
  },
  "scripts": {
    "start": "node server.js",
    "data:hsk": "python3 scripts/generate_hsk_data.py",
    "agents:plan": "node scripts/agent-coordinator.js",

{
  "name": "hsk-study-server",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "pg": "^8.19.0"
  },
  "scripts": {
    "start": "node server.js",
    "data:hsk": "python3 scripts/generate_hsk_data.py",
    "agents:plan": "node scripts/agent-coordinator.js",
    "test:e2e": "playwright test tests/e2e/frontend-smoke.spec.js",
    "test:agents": "node --test tests/agent-coordinator.spec.js",
    "test:recognition": "node --test tests/recognition-core.spec.js",
    "test:submissions": "node --test tests/submissions-judge-detail.spec.js",
    "test:ocr-api": "node --test tests/ocr-proxy.spec.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2"
  }
}

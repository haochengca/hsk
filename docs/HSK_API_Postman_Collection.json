{
  "info": {
    "name": "HSK Study API",
    "_postman_id": "9b5c44b7-8b76-4a7e-8d89-b90f5a61b1f7",
    "description": "HSK 学习与默写系统 API 集合（含用户与管理员流程）",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
      }
    },
    {
      "name": "User Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"user_demo\",\n  \"password\": \"pass1234\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/register", "host": ["{{baseUrl}}"], "path": ["api", "register"] }
      }
    },
    {
      "name": "User Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"user_demo\",\n  \"password\": \"pass1234\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api", "login"] }
      },
      "event": [{
        "listen": "test",
        "script": { "type": "text/javascript", "exec": [
          "const json = pm.response.json();",
          "if (json && json.token) pm.collectionVariables.set('token', json.token);"
        ]}
      }]
    },
    {
      "name": "Admin Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api", "login"] }
      },
      "event": [{
        "listen": "test",
        "script": { "type": "text/javascript", "exec": [
          "const json = pm.response.json();",
          "if (json && json.token) pm.collectionVariables.set('adminToken', json.token);"
        ]}
      }]
    },
    {
      "name": "Bootstrap",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/bootstrap", "host": ["{{baseUrl}}"], "path": ["api", "bootstrap"] }
      }
    },
    {
      "name": "Save User Data",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"progress\": {},\n  \"wrongBook\": [],\n  \"rewards\": {\n    \"totalPoints\": 1,\n    \"weeklyPoints\": 1,\n    \"weeklyCorrect\": 1,\n    \"currentWeekKey\": \"2026-03-02\",\n    \"lastUpdatedAt\": 1760000000000\n  },\n  \"reviewPrefs\": {\n    \"reviewType\": \"char\",\n    \"reviewLevel\": \"1\",\n    \"reviewCount\": \"10\",\n    \"reviewWrongMixRatio\": \"30\"\n  }\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/user-data", "host": ["{{baseUrl}}"], "path": ["api", "user-data"] }
      }
    },
    {
      "name": "Create Submission (Word)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"word\",\n  \"target\": \"你好\",\n  \"pinyin\": \"ni hao\",\n  \"userAnswer\": \"第1字正确(90%)，第2字错误(52%)\",\n  \"handwritingImage\": \"data:image/png;base64,AAA||data:image/png;base64,BBB\",\n  \"accuracyPercent\": 71,\n  \"systemResult\": false,\n  \"finalResult\": false,\n  \"pointsAwarded\": 1,\n  \"wordCharResults\": [\n    {\n      \"char\": \"你\",\n      \"isGood\": true,\n      \"accuracyPercent\": 90,\n      \"handwritingImage\": \"data:image/png;base64,AAA\"\n    },\n    {\n      \"char\": \"好\",\n      \"isGood\": false,\n      \"accuracyPercent\": 52,\n      \"handwritingImage\": \"data:image/png;base64,BBB\"\n    }\n  ]\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/submissions", "host": ["{{baseUrl}}"], "path": ["api", "submissions"] }
      },
      "event": [{
        "listen": "test",
        "script": { "type": "text/javascript", "exec": [
          "const json = pm.response.json();",
          "if (json && json.submission && json.submission.id) pm.collectionVariables.set('submissionId', json.submission.id);"
        ]}
      }]
    },
    {
      "name": "Admin Review Submission (Per-word Per-char)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"finalResult\": false,\n  \"wordCharResults\": [\n    {\n      \"char\": \"你\",\n      \"isGood\": true,\n      \"accuracyPercent\": 90,\n      \"handwritingImage\": \"data:image/png;base64,AAA\"\n    },\n    {\n      \"char\": \"好\",\n      \"isGood\": false,\n      \"accuracyPercent\": 52,\n      \"handwritingImage\": \"data:image/png;base64,BBB\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/submissions/{{submissionId}}/review",
          "host": ["{{baseUrl}}"],
          "path": ["api", "submissions", "{{submissionId}}", "review"]
        }
      }
    },
    {
      "name": "User Logout",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/logout", "host": ["{{baseUrl}}"], "path": ["api", "logout"] }
      }
    },
    {
      "name": "Admin Logout",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/logout", "host": ["{{baseUrl}}"], "path": ["api", "logout"] }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8787" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "submissionId", "value": "" }
  ]
}
